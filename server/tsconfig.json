{
  "compilerOptions": {
    "target": "ESNext",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "lib": ["ESNext"],
    "types": ["node"], 
    
    "rootDir": ".",
    "outDir": "./dist",

    "strict": true,
    "verbatimModuleSyntax": false, 
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    
    "sourceMap": true,
    "declaration": true
  },
  "include": ["index.ts", "src/**/*"],
  "exclude": ["node_modules"]
}